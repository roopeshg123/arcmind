# ─────────────────────────────────────────────────────────────────────────────
# ArcMind — environment configuration
# Fill in your values below. This file is safe to commit — it contains
# only placeholder values. Never paste real API keys into this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Set CHAT_PROVIDER to "openai" (default) or "claude" to switch LLM backends.
CHAT_PROVIDER=claude

# OpenAI — used when CHAT_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic Claude — used when CHAT_PROVIDER=claude
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Security (optional) ───────────────────────────────────────────────────────
# When set, all /api/* requests must include the header: X-API-Key: <value>
# Leave blank to disable authentication (local dev only).
API_KEY=

# CORS: comma-separated list of allowed origins. Use * to allow all (dev only).
# Example: https://yoursite.com,https://app.yoursite.com
CORS_ORIGINS=*

# ── Models ───────────────────────────────────────────────────────────────────
# ⚠️  IMPORTANT: If you change CHAT_MODEL or EMBEDDING_MODEL you MUST delete
#    chroma_db/ and re-index (click ⚡ Index Docs or run: python ingest.py --reset)
#
# CHAT_MODEL options:
#   OpenAI  (CHAT_PROVIDER=openai):
#     gpt-4.1       → best quality, latest model  (recommended)
#     gpt-4o        → very strong, slightly older
#     gpt-4o-mini   → faster & cheaper, slightly lower quality
#
#   Claude  (CHAT_PROVIDER=claude):
#     claude-opus-4-5   → most capable, best for complex reasoning
#     claude-sonnet-4-5 → balanced quality & speed  (recommended)
#     claude-haiku-3-5  → fastest & cheapest
#
# EMBEDDING_MODEL options (changing requires full re-index):
#   OpenAI  (EMBEDDING_PROVIDER=openai):
#     text-embedding-3-large  → highest accuracy, 3072 dims  (recommended)
#     text-embedding-3-small  → faster & cheaper, 1536 dims
#
#   HuggingFace  (EMBEDDING_PROVIDER=huggingface) — FREE, runs locally, no API key needed:
#     BAAI/bge-small-en-v1.5                   → fast & good quality  (recommended for local)
#     sentence-transformers/all-MiniLM-L6-v2   → fastest, lightest (~90MB)
#     BAAI/bge-large-en-v1.5                   → best quality but slow (1.34GB, not recommended on CPU)
#
# ⚠️  Switching EMBEDDING_PROVIDER or EMBEDDING_MODEL requires a full re-index:
#     delete chroma_db/ then click ⚡ Index Docs (or run: python ingest.py --reset)
EMBEDDING_PROVIDER=openai
CHAT_MODEL=claude-sonnet-4-5
EMBEDDING_MODEL=text-embedding-3-large

# ── Docs source (choose ONE, comment out the other) ──────────────────────────

# Option A — local folder of HTML docs.
#   Docker Compose mounts this path into the container automatically.
DOCS_DIR=./docs

# Option B — crawl docs over HTTP instead of a local folder.
#   For Docker on Windows, use host.docker.internal to reach the host machine.
# DOCS_URL=http://host.docker.internal:8081/

# Max pages to crawl when using DOCS_URL (prevents unbounded crawls)
MAX_CRAWL_PAGES=2000

# ── Chunking ─────────────────────────────────────────────────────────────────
# ⚠️  Changing these requires a full re-index (delete chroma_db/ first).
# CHUNK_SIZE    — tokens per chunk. Larger = more context but fewer results fit.
# CHUNK_OVERLAP — tokens shared between adjacent chunks (prevents cut sentences).
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# ── Retrieval ─────────────────────────────────────────────────────────────────
# RETRIEVER_TOP_K — candidate chunks fetched from each collection before reranking.
# DOCS_TOP_K      — doc chunks passed to the LLM after reranking.
# JIRA_TOP_K      — Jira chunks passed to the LLM after reranking.
RETRIEVER_TOP_K=15
DOCS_TOP_K=8
JIRA_TOP_K=6

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=8

# ── HuggingFace Hub (optional) ────────────────────────────────────────────────
# Suppresses the "unauthenticated requests" warning and gives higher download rate limits.
# Get a free Read token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────
# For Docker: this is overridden to /app/chroma_db in docker-compose.yml
CHROMA_DB_DIR=./chroma_db

# ── Jira connector (optional — leave blank to disable) ────────────────────────
# Your Atlassian Cloud base URL (no trailing slash):
JIRA_URL=https://your-org.atlassian.net
# The email address you log into Jira with:
JIRA_EMAIL=
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# The Jira project key to index (e.g. ARC, ARCESB, SUPPORT):
JIRA_PROJECT_KEY=YOUR_PROJECT

# ── Confluence connector (optional — leave blank to disable) ──────────────────
# Same Atlassian Cloud base URL as Jira (no trailing slash):
CONFLUENCE_URL=https://your-org.atlassian.net
# Same email address as Jira:
CONFLUENCE_EMAIL=
# Same API token as Jira (or generate one at https://id.atlassian.com/manage-profile/security/api-tokens):
CONFLUENCE_API_TOKEN=
# Comma-separated list of Confluence space keys to index (e.g. DOCS,KB,SUPPORT):
CONFLUENCE_SPACES=DOCS,KB
# Number of pages to fetch per API request (default: 100, max: 250):
CONFLUENCE_PAGE_SIZE=100
# Confluence chunks passed to the LLM after reranking:
CONFLUENCE_TOP_K=4
