# ─────────────────────────────────────────────────────────────────
# ArcMind — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains your API key.
# ─────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...replace-with-your-real-key...

# ── Models ───────────────────────────────────────────────────────
CHAT_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-large

# ── Docs source (choose ONE, comment out the other) ───────────────

# DOCS_DIR — path to your folder of HTML docs.
#   Works for BOTH local Python AND Docker — no changes needed when switching.
#   Docker Compose mounts this Windows path into the container automatically.
DOCS_DIR=C:\path\to\your\html\docs

# DOCS_URL — alternative: crawl docs from an HTTP URL instead of a local folder.
#   Uncomment this (and comment out DOCS_DIR) to use a URL source.
#   For Docker on Windows, use host.docker.internal to reach the host machine:
# DOCS_URL=http://host.docker.internal:8081/

# ── Chunking ─────────────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# ── Retrieval ────────────────────────────────────────────────────
RETRIEVER_TOP_K=15
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=8

# ── Storage ──────────────────────────────────────────────────────
# For Docker: this is overridden to /app/chroma_db in docker-compose.yml
CHROMA_DB_DIR=./chroma_db

# ── Jira connector (optional — leave blank to disable) ──────────
# Your Atlassian Cloud base URL (no trailing slash):
JIRA_URL=https://your-org.atlassian.net
# The email address you log into Jira with:
JIRA_EMAIL=you@yourcompany.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token
# The Jira project key to index (e.g. ARC, SUPPORT, OPS):
JIRA_PROJECT_KEY=ARC
